# Copy to .env.local and fill in. Do not commit .env.local or the key file.

# Absolute path to your Google Cloud service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# GA4: Property ID (Admin → Property settings in analytics.google.com)
GA4_PROPERTY_ID=123456789

# GSC: Exact site URL from Search Console (e.g. https://www.example.com/)
GSC_SITE_URL=https://www.yourdomain.com/
